# Rootstock (RSK) Testnet RPC URL — use an authenticated endpoint for full EVM support
RPC_URL=https://rpc.testnet.rootstock.io/<YOUR_API_KEY>

# Private key of the keeper wallet (without 0x prefix)
# WARNING: Never commit the real .env file to version control
KEEPER_PRIVATE_KEY=your_private_key_here

# Deployed ProofOfLiveness contract address
CONTRACT_ADDRESS=0xa51cbd66985ddd1a04858d8be11bf26be32f3870

# How often to poll for slashable participants (milliseconds)
POLL_INTERVAL_MS=30000

# Gas limit for slash transactions (RSK has lower block gas limits than Ethereum)
GAS_LIMIT=200000

# Block number to start scanning from (set to deployment block for efficiency)
SCAN_FROM_BLOCK=7486430

# Port for the health-check HTTP endpoint (GET /health)
HEALTH_PORT=3001

# Max retry attempts for RPC calls (uses exponential backoff)
MAX_RETRIES=5

# Base delay in milliseconds for the first retry
RETRY_BASE_MS=1000
